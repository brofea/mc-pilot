MC_PILOT_ENVIRONMENT=development
MC_PILOT_HOST=127.0.0.1
MC_PILOT_PORT=8000
MC_PILOT_LOG_LEVEL=INFO
MC_PILOT_SQLITE_URL=sqlite:///data/mc_pilot.db
MC_PILOT_QDRANT_URL=http://localhost:6333
MC_PILOT_QDRANT_TIMEOUT_SECONDS=2
# Docker Desktop/macOS: directory containing logs/latest.log.
MC_PILOT_MINECRAFT_DIR=/Users/your-name/Library/Application Support/minecraft
# Native (non-Docker) override; Docker sets this to /minecraft/logs/latest.log.
MC_PILOT_GAME_LOG_PATH=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
